<div class="container my-4">
  <!-- Feature 4.1.3 — Breadcrumbs -->
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
      <li class="breadcrumb-item">
        <%= link_to @product.category.name, category_path(@product.category) %>
      </li>
      <li class="breadcrumb-item active"><%= @product.name %></li>
    </ol>
  </nav>

  <div class="row g-4">
    <div class="col-lg-5">
      <% if @product.image.attached? %>
        <%= image_tag @product.image, class: "img-fluid rounded shadow" %>
      <% else %>
        <div class="d-flex align-items-center justify-content-center bg-dark rounded" style="height:350px;">
          <span style="font-size:6rem;">🎮</span>
        </div>
      <% end %>
    </div>

    <div class="col-lg-7">
      <h1 class="fw-bold"><%= @product.name %></h1>
      <p>
        Category: <%= link_to @product.category.name, category_path(@product.category),
          class: "badge bg-secondary text-decoration-none fs-6" %>
        <span class="badge bg-dark ms-2"><%= @product.condition %></span>
      </p>

      <% if @product.on_sale? && @product.sale_price %>
        <h2 class="text-danger fw-bold">$<%= sprintf("%.2f", @product.sale_price) %></h2>
        <p class="text-muted text-decoration-line-through">Was: $<%= sprintf("%.2f", @product.price) %></p>
      <% else %>
        <h2 class="text-success fw-bold">$<%= sprintf("%.2f", @product.price) %></h2>
      <% end %>

      <% if @product.stock_quantity > 0 %>
        <p class="text-success">✅ In Stock (<%= @product.stock_quantity %> available)</p>
      <% else %>
        <p class="text-danger">❌ Out of Stock</p>
      <% end %>

      <hr>
      <p><%= @product.description %></p>

      <% if @product.stock_quantity > 0 %>
        <%= button_to "🛒 Add to Cart", add_item_cart_path,
            params: { product_id: @product.id },
            method: :post,
            class: "btn btn-danger btn-lg" %>
      <% end %>
    </div>
  </div>
</div>