<div class="col">
  <div class="card h-100 shadow-sm border-0" style="transition: transform 0.2s;"
       onmouseover="this.style.transform='translateY(-4px)'"
       onmouseout="this.style.transform='translateY(0)'">

    <%= link_to product_path(product), class: "text-decoration-none" do %>
      <% if product.image.attached? %>
        <%= image_tag product.image, class: "card-img-top", style: "height:180px;object-fit:cover;" %>
      <% else %>
        <div class="d-flex align-items-center justify-content-center bg-dark" style="height:180px;">
          <span style="font-size:3.5rem;">🎮</span>
        </div>
      <% end %>
    <% end %>

    <div class="card-body d-flex flex-column">
      <div class="d-flex justify-content-between mb-1">
        <span class="badge bg-secondary small"><%= product.condition %></span>
        <%= link_to product.category.name, category_path(product.category),
            class: "badge bg-light text-dark text-decoration-none small" %>
      </div>

      <h6 class="card-title fw-bold">
        <%= link_to product.name, product_path(product), class: "text-decoration-none text-dark" %>
      </h6>

      <div class="mt-auto">
        <% if product.on_sale? && product.sale_price %>
          <span class="fw-bold text-danger fs-5">$<%= sprintf("%.2f", product.sale_price) %></span>
          <span class="text-muted text-decoration-line-through small ms-1">
            $<%= sprintf("%.2f", product.price) %>
          </span>
          <span class="badge bg-danger ms-1">SALE</span>
        <% else %>
          <span class="fw-bold text-success fs-5">$<%= sprintf("%.2f", product.price) %></span>
        <% end %>

        <% if product.stock_quantity > 0 %>
          <small class="text-success d-block">✓ In Stock</small>
        <% else %>
          <small class="text-danger d-block">✗ Out of Stock</small>
        <% end %>

        <!-- Feature 4.2.3 — session used for cart -->
        <%= button_to "Add to Cart", add_item_cart_path,
            params: { product_id: product.id },
            method: :post,
            class: "btn btn-outline-danger btn-sm w-100 mt-2",
            disabled: product.stock_quantity == 0 %>
      </div>
    </div>
  </div>
</div>