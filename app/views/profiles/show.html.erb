<div class="container my-4">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
          <h5 class="mb-0">My Account</h5>
        </div>
        <div class="card-body">
          <h6 class="fw-bold"><%= current_user.name %></h6>
          <p class="text-muted mb-1"><%= current_user.email %></p>

          <% if current_user.address.present? %>
            <hr>
            <p class="mb-0"><strong>Address:</strong><br>
            <%= current_user.address %><br>
            <%= current_user.city %><br>
            <%= current_user.province&.name %><br>
            <%= current_user.postal_code %></p>
          <% else %>
            <hr>
            <p class="text-muted">No address saved yet.</p>
          <% end %>

          <hr>
          <%= link_to "Edit Profile", edit_profile_path, class: "btn btn-outline-danger btn-sm w-100" %>
        </div>
      </div>
    </div>

    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
          <h5 class="mb-0">Recent Orders</h5>
        </div>
        <div class="card-body">
          <% if @orders.present? && @orders.any? %>
            <% @orders.each do |order| %>
              <div class="border-bottom pb-2 mb-2">
                <div class="d-flex justify-content-between">
                  <div>
                    <strong>Order #<%= order.id %></strong>
                    <span class="badge bg-<%= order.status == 'paid' || order.status == 'shipped' ? 'success' : 'warning text-dark' %> ms-2">
                      <%= order.status.capitalize %>
                    </span>
                    <p class="small text-muted mb-0"><%= order.created_at.strftime("%B %d, %Y") %></p>
                  </div>
                  <div class="text-end">
                    <p class="fw-bold text-success mb-0">$<%= sprintf("%.2f", order.total) %></p>
                    <%= link_to "View Details", order_path(order), class: "small" %>
                  </div>
                </div>
              </div>
            <% end %>
            <div class="mt-3 text-center">
              <%= link_to "View All Orders", orders_path, class: "btn btn-sm btn-outline-secondary" %>
            </div>
          <% else %>
            <p class="text-muted text-center mb-0">No orders yet.</p>
            <%= link_to "Start Shopping", products_path, class: "btn btn-sm btn-danger mt-3 w-100" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>