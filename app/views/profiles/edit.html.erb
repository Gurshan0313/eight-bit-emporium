<div class="container my-4" style="max-width: 600px;">
  <h1 class="fw-bold mb-4">Edit Profile</h1>

  <%= form_for current_user, url: profile_path, method: :patch do |f| %>
    <% if current_user.errors.any? %>
      <div class="alert alert-danger">
        <h6>Errors prevented this profile from being saved:</h6>
        <ul>
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="mb-3">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-control", required: true, disabled: true %>
      <div class="form-text">Email cannot be changed here.</div>
    </div>

    <div class="mb-3">
      <%= f.label :address, class: "form-label" %>
      <%= f.text_field :address, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :city, class: "form-label" %>
      <%= f.text_field :city, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :province_id, "Province", class: "form-label" %>
      <%= f.collection_select :province_id, @provinces, :id, :name, { include_blank: "Select province" }, { class: "form-select" } %>
    </div>

    <div class="mb-3">
      <%= f.label :postal_code, class: "form-label" %>
      <%= f.text_field :postal_code, class: "form-control", placeholder: "A1A 1A1" %>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "Update Profile", class: "btn btn-danger" %>
      <%= link_to "Cancel", profile_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>

  <hr class="my-4">

  <div class="card border-danger">
    <div class="card-body">
      <h6 class="text-danger">Danger Zone</h6>
      <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-danger btn-sm" %>
    </div>
  </div>
</div>