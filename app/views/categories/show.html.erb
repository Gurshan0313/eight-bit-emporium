<div class="bg-dark text-white py-4 border-bottom border-danger border-3">
  <div class="container">
    <h1 class="fw-bold">🎮 <%= @category.name %></h1>
    <p class="text-muted mb-0"><%= @category.description %></p>
  </div>
</div>

<div class="container my-4">

  <!-- Feature 4.1.3 — Breadcrumbs -->
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Categories", categories_path %></li>
      <li class="breadcrumb-item active"><%= @category.name %></li>
    </ol>
  </nav>

  <% if @products.empty? %>
    <div class="text-center py-5">
      <p class="display-1">🎮</p>
      <h3>No products in this category yet</h3>
      <%= link_to "Browse All Products", products_path, class: "btn btn-danger" %>
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
      <% @products.each do |product| %>
        <%= render "products/product_card", product: product %>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-center mt-5">
      <%= paginate @products %>
    </div>
  <% end %>
</div>