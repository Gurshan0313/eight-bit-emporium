<div class="bg-dark text-white py-4 border-bottom border-danger border-3">
  <div class="container">
    <h1 class="fw-bold">📁 All Categories</h1>
    <p class="text-muted mb-0">Browse our collection by category</p>
  </div>
</div>

<div class="container my-4">
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% @categories.each do |category| %>
      <div class="col">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body text-center">
            <span class="display-1">🎮</span>
            <h5 class="card-title mt-2">
              <%= link_to category.name, category_path(category), class: "text-decoration-none text-dark" %>
            </h5>
            <p class="card-text text-muted small"><%= truncate(category.description, length: 100) %></p>
            <p class="fw-bold text-danger"><%= category.products.count %> products</p>
            <%= link_to "Browse →", category_path(category), class: "btn btn-sm btn-outline-danger" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>